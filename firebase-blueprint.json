{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with SaaS subscription data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "apiKey": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "quota": { "type": "number" },
        "usedQuota": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "role", "apiKey", "plan", "quota", "usedQuota", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    }
  }
}
